@model BinaryCity.ViewModel.ContactDetailsViewModel

@{
    ViewData["Title"] = "Contact Details";
}

<h1>Contact Details</h1>

<ul class="nav nav-tabs" role="tablist">
    <li class="nav-item">
        <button class="nav-link active"
                data-bs-toggle="tab"
                data-bs-target="#general"
                type="button">
            General
        </button>
    </li>
    <li class="nav-item">
        <button class="nav-link"
                data-bs-toggle="tab"
                data-bs-target="#clients"
                type="button">
            Client(s)
        </button>
    </li>
</ul>

<div class="tab-content mt-3">

    <!-- GENERAL TAB -->
    <div class="tab-pane fade show active" id="general">
        <dl class="row">
            <dt class="col-sm-2">Name</dt>
            <dd class="col-sm-10">@Model.Name</dd>

            <dt class="col-sm-2">Surname</dt>
            <dd class="col-sm-10">@Model.Surname</dd>

            <dt class="col-sm-2">Email</dt>
            <dd class="col-sm-10">@Model.Email</dd>
        </dl>
    </div>

    <!-- CLIENTS TAB -->
    <div class="tab-pane fade" id="clients">

        <h5>Link a client</h5>

        @if (!Model.AvailableClients.Any())
        {
            <div class="text-muted">No client(s) available to link.</div>
        }
        else
        {
            <div class="input-group mb-3">
                <select id="available-client-select" class="form-select">
                    @foreach (var c in Model.AvailableClients)
                    {
                        <option value="@c.ClientId">@c.Name (@c.ClientCode)</option>
                    }
                </select>
                <button class="btn btn-primary mt-2"
                        id="link-client-btn"
                        data-contact="@Model.ContactId">
                    Link
                </button>
            </div>
        }
        <hr />

        <h4>Linked Clients</h4>

        @if (!Model.LinkedClients.Any())
        {
            <div class="alert alert-info">No client(s) linked.</div>
        }
        else
        {
            <table class="table">
                <thead>
                    <tr>
                        <th>Client name</th>
                        <th>Client code</th>
                        <th></th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var c in Model.LinkedClients)
                    {
                        <tr>
                            <td>@c.Name</td>
                            <td>@c.ClientCode</td>
                            <td>
                                <button class="btn btn-link btn-sm unlink-client-btn"
                                        data-contact="@Model.ContactId"
                                        data-client="@c.ClientId">
                                    Unlink
                                </button>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        }

        <hr />

       
    </div>
</div>

<a asp-action="Index" class="btn btn-secondary mt-3">Back to list</a>

@section Scripts {
    <script>
        (function () {

            function postJson(url, body) {
                return fetch(url, {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify(body)
                }).then(r => r.json());
            }

            document.getElementById('link-client-btn')?.addEventListener('click', function () {
                postJson('/Contact/LinkClientAjax', {
                    contactId: parseInt(this.dataset.contact),
                    clientId: parseInt(document.getElementById('available-client-select').value)
                }).then(r => {
                    if (r.success) {
                        window.location.hash = '#clients';
                        location.reload();
                    }
                });
            });

            document.querySelectorAll('.unlink-client-btn').forEach(btn => {
                btn.addEventListener('click', function () {
                    postJson('/Contact/UnlinkClientAjax', {
                        contactId: parseInt(this.dataset.contact),
                        clientId: parseInt(this.dataset.client)
                    }).then(r => {
                        if (r.success) {
                            window.location.hash = '#clients';
                            location.reload();
                        }
                    });
                });
            });

            // Restore active tab after reload
            const hash = window.location.hash;
            if (hash) {
                const tabBtn = document.querySelector(`button[data-bs-target="${hash}"]`);
                if (tabBtn) {
                    new bootstrap.Tab(tabBtn).show();
                }
            }

        })();
    </script>
}