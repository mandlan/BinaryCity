@model IEnumerable<BinaryCity.ViewModel.ContactListItemViewModel>

<h1>Contacts</h1>

<a class="btn btn-primary mb-3" asp-action="Create">Create New Contact</a>

@if (!Model.Any())
{
    <div class="alert alert-info">No contact(s) found.</div>
}
else
{
    <table class="table table-striped">
        <thead>
            <tr>
                <th>Name</th>
                <th>Surname</th>
                <th>Email</th>
                <th class="text-center">No. of linked Clients</th>
                <th></th>
            </tr>
        </thead>
        <tbody>
            @foreach (var c in Model)
            {
                <tr>
                    <td>@c.Name</td>
                    <td>@c.Surname</td>
                    <td>@c.Email</td>
                    <td class="text-center">@c.LinkedClientsCount</td>
                    <td>
                        <a asp-action="Details" asp-route-id="@c.ContactId">Details</a>
                    </td>
                </tr>
            }
        </tbody>
    </table>
}