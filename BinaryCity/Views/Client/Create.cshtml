@model BinaryCity.ViewModel.ClientCreateViewModel

@{
    ViewData["Title"] = "Create Client";
}

<h1>Create Client</h1>

<form asp-action="Create" method="post" id="client-create-form" novalidate>
    @Html.AntiForgeryToken()

    <div asp-validation-summary="ModelOnly" class="text-danger"></div>

    <div class="mb-3">
        <label asp-for="Name" class="form-label"></label>
        <input asp-for="Name" class="form-control" />
        <span asp-validation-for="Name" class="text-danger"></span>
    </div>

    <!-- ClientCode must NOT appear for new client -->

    <button type="submit" class="btn btn-primary" id="client-save-btn">Save</button>
    <a asp-action="Index" class="btn btn-secondary">Cancel</a>
</form>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}