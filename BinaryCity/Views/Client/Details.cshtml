@model BinaryCity.ViewModel.ClientDetailsViewModel

<h2>Client Details</h2>

<ul class="nav nav-tabs" role="tablist">
    <li class="nav-item">
        <button class="nav-link active"
                data-bs-toggle="tab"
                data-bs-target="#general"
                type="button">
            General
        </button>
    </li>
    <li class="nav-item">
        <button class="nav-link"
                data-bs-toggle="tab"
                data-bs-target="#contacts"
                type="button">
            Contact(s)
        </button>
    </li>
</ul>

<div class="tab-content mt-3">

    <!-- GENERAL TAB -->
    <div class="tab-pane fade show active" id="general">
        <p><strong>Name:</strong> @Model.Name</p>
        <p><strong>Client Code:</strong> @Model.ClientCode</p>
    </div>

    <!-- CONTACTS TAB -->
    <div class="tab-pane fade" id="contacts">

        <h5>Link Contact</h5>

        @if (!Model.AvailableContacts.Any())
        {
            <div class="text-muted">All contacts are already linked.</div>
        }
        else
        {
            <form asp-action="LinkContact" method="post">
                @Html.AntiForgeryToken()
                <input type="hidden" name="clientId" value="@Model.ClientId" />

                <select name="contactId" class="form-select" required>
                    <option value="">-- Select Contact --</option>
                    @foreach (var c in Model.AvailableContacts)
                    {
                        <option value="@c.ContactId">@c.FullName (@c.Email)</option>
                    }
                </select>
                <button class="btn btn-primary mt-2">Link</button>
            </form>
        }
        <hr />
        <h4>Linked Contacts</h4>

        @if (!Model.LinkedContacts.Any())
        {
            <div class="alert alert-info">No contacts found.</div>
        }
        else
        {
            <table class="table">
                <thead>
                    <tr>
                        <th>Full Name</th>
                        <th>Email</th>
                        <th></th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var c in Model.LinkedContacts)
                    {
                        <tr>
                            <td>@c.FullName</td>
                            <td>@c.Email</td>
                            <td>
                                <form asp-action="Unlink" method="post">
                                    @Html.AntiForgeryToken()
                                    <input type="hidden" name="clientId" value="@Model.ClientId" />
                                    <input type="hidden" name="contactId" value="@c.ContactId" />
                                    <button class="btn btn-sm btn-link">Unlink</button>
                                </form>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        }

     

       
    </div>
</div>

<a asp-action="Index" class="btn btn-secondary mt-3">Back to list</a>

@section Scripts {
    <script>
        // Restore tab after reload 
        document.addEventListener('DOMContentLoaded', function () {
            const hash = window.location.hash;
            if (hash) {
                const tabBtn = document.querySelector(`button[data-bs-target="${hash}"]`);
                if (tabBtn) {
                    new bootstrap.Tab(tabBtn).show();
                }
            }
        });
    </script>
}