@model IEnumerable<BinaryCity.ViewModel.ClientListItemViewModel>

<h1>Clients</h1>

<a class="btn btn-primary mb-3" asp-action="Create">Create New Client</a>

@if (!Model.Any())
{
    <div class="alert alert-info">No client(s) found.</div>
}
else
{
    <table class="table table-striped">
        <thead>
            <tr>
                <th>Name</th>
                <th>Client Code</th>
                <th class="text-center">Linked Contacts</th>
                <th></th>
            </tr>
        </thead>
        <tbody>
            @foreach (var c in Model)
            {
                <tr>
                    <td>@c.Name</td>
                    <td>@c.ClientCode</td>
                    <td class="text-center">@c.LinkedContactsCount</td>
                    <td>
                        <a asp-action="Details" asp-route-id="@c.ClientId">Details</a>
                    </td>
                </tr>
            }
        </tbody>
    </table>
}